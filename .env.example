# Optional locations for the lightweight local work-session stores.
AVEN_SESSION_STORE=./data/work-sessions.json
AVEN_CLI_TOKEN_STORE=./data/cli-tokens.json

# Set this after deploying the extended stream_contract to Stellar testnet.
NEXT_PUBLIC_STREAM_CONTRACT_ID=C...
NEXT_PUBLIC_ATTESTATION_CONTRACT_ID=C...
NEXT_PUBLIC_REPUTATION_CONTRACT_ID=C...

# Server-only signer used to record verified work claims. Never expose this
# value through a NEXT_PUBLIC variable or commit a real secret.
AVEN_VERIFIER_SECRET=S...
