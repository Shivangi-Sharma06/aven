# Optional locations for the lightweight local work-session stores.
AVEN_SESSION_STORE=./data/work-sessions.json
AVEN_CLI_TOKEN_STORE=./data/cli-tokens.json

# Required in production. Shared persistence makes work sessions and CLI
# authorizations available across devices and serverless instances.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Optional explicit namespace. Defaults to NEXT_PUBLIC_STREAM_CONTRACT_ID so a
# fresh contract deployment starts with an empty application data set.
AVEN_DATA_NAMESPACE=

# Set this after deploying the extended stream_contract to Stellar testnet.
NEXT_PUBLIC_STREAM_CONTRACT_ID=C...
NEXT_PUBLIC_ATTESTATION_CONTRACT_ID=C...

# Server-only signer used to record verified work claims. Never expose this
# value through a NEXT_PUBLIC variable or commit a real secret.
AVEN_VERIFIER_SECRET=S...

# ─── GitHub App integration (server-only — never use NEXT_PUBLIC_) ───────────
# GitHub App numeric ID (visible on the App settings page).
GITHUB_APP_ID=
# RSA private key for the GitHub App. In single-line env vars, replace every
# literal newline with \n (the getGithubEnv() function normalises them).
GITHUB_APP_PRIVATE_KEY=
# Installation ID for the Aven org (visible under App > Installations).
GITHUB_APP_INSTALLATION_ID=
# Webhook secret configured in the GitHub App settings.
GITHUB_WEBHOOK_SECRET=
# The GitHub organisation under which project repositories are created.
GITHUB_AVEN_ORG=
# OAuth App client ID (for linking worker GitHub accounts).
GITHUB_OAUTH_CLIENT_ID=
# OAuth App client secret — never expose to the browser.
GITHUB_OAUTH_CLIENT_SECRET=
# OAuth redirect URI registered in the GitHub OAuth App settings.
# Production: https://your-domain.com/api/github/callback
# Local:      http://localhost:3000/api/github/callback
GITHUB_OAUTH_REDIRECT_URI=
