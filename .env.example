# Manual work verification runs locally by default. Production deployments must
# opt in only after placing the verification API behind authentication and an
# authenticated, rate-limited verification worker boundary.
ENABLE_MANUAL_VERIFICATION=false

# Optional Groq report generation for code and creative text. Keep this server-side.
GROQ_API_KEY=gsk_...
GROQ_MODEL=openai/gpt-oss-20b
VERIFICATION_SCORE_THRESHOLD=50

# Optional locations for the lightweight local work-session stores.
AVEN_SESSION_STORE=./data/work-sessions.json
AVEN_CLI_TOKEN_STORE=./data/cli-tokens.json

# Enable only after deploying the stream contract version that exposes the
# reviewed-withdrawal methods generated in contracts/bindings/stream.
NEXT_PUBLIC_STRICT_REVIEWED_WITHDRAWALS=false
